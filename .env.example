# .env.example — Copie este arquivo para .env e preencha os valores reais
# Este arquivo PODE ir para o GitHub. O .env NÃO DEVE ir!

# Oracle Database
ORACLE_PASSWORD=SUA_SENHA_DO_BANCO_AQUI

# E-mail de destino das mensagens de contato
EMAIL_TO=seu-email@gmail.com

# Gmail (App Password — gerado em myaccount.google.com/apppasswords)
GMAIL_FROM=seu-email-remetente@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Chave secreta para assinatura dos Magic Link tokens
JWT_SECRET=UmaChaveSuperSecretaComPeloMenos32Caracteres!
