<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Exclude>[Portfolio.API]Microsoft.AspNetCore.OpenApi.*,[Portfolio.API]Portfolio.API.Migrations.*,[Portfolio.API]Portfolio.API.Data.DataSeeder</Exclude>
          <ExcludeByFile>**\*.generated.cs,**\Migrations\*.cs,**\DataSeeder.cs</ExcludeByFile>
          <ExcludeByAttribute>GeneratedCodeAttribute,CompilerGeneratedAttribute,ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
